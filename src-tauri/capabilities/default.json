{
  "identifier": "default",
  "description": "Default capabilities for pizz",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "cors-fetch:default",
    "cors-fetch:allow-fetch",
    "cors-fetch:allow-fetch-cancel",
    "cors-fetch:allow-fetch-send",
    "cors-fetch:allow-fetch-read-body",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    "fs:allow-read-dir",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select"
  ]
}
